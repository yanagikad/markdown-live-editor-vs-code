{
  "name": "markdown-live-editor-vs-code",
  "displayName": "Markdown Live Editor",
  "description": "Live markdown preview editor for VS Code with in-place editing.",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:markdownLiveEditor.openPreview"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownLiveEditor.openPreview",
        "title": "Markdown Live Editor: Open Live Preview"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && cp src/infrastructure/webview/webviewTemplate.html out/infrastructure/webview/webviewTemplate.html",
    "watch": "tsc -watch -p ./",
    "lint": "echo 'No lint configured yet'"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  }
}
